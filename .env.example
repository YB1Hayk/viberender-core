# VibeRender — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the deployer/validator wallet (no 0x prefix needed for hardhat)
DEPLOYER_KEY=

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
# Get free endpoints from Alchemy, Infura, or QuickNode
BASE_SEPOLIA_RPC=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_MAINNET_RPC=https://mainnet.base.org
ARBITRUM_MAINNET_RPC=https://arb1.arbitrum.io/rpc

# ── Block Explorer API Keys (for contract verification) ───────────────────────
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# ── Deployed Contract Addresses (populated after running scripts/deploy.js) ───
RENDER_ESCROW_BASE_SEPOLIA=
RENDER_ESCROW_ARBITRUM_SEPOLIA=
JOB_REGISTRY_BASE_SEPOLIA=
JOB_REGISTRY_ARBITRUM_SEPOLIA=
